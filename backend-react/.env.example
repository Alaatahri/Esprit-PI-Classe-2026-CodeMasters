# Front admin — copier vers .env.local
# API Nest (proxy Vite /api → 3001) — utilisateurs, projets Nest
# VITE_API_URL non requis si vous utilisez uniquement le proxy /api

# Matching + Socket.io (Express sur 5050)
VITE_MATCHING_API_URL=http://localhost:5050/api
VITE_SOCKET_URL=http://localhost:5050

# Optionnel : id MongoDB pour tests dashboard travailleur
# VITE_WORKER_ID=
