# Copier vers .env — variables optionnelles
# Depuis la racine du dépôt : npm run dev (lance backend + frontend Next.js)
#
# NODE_ENV=development
# MONGODB_URI=mongodb://localhost:27017/bmp-tn

# --- E-mail (vérification d’inscription) ---
# FRONTEND_URL=http://localhost:3000  (lien « Confirmer » dans l’e-mail)
#
# Avec MAIL_* (Gmail, etc.) : livraison réelle vers l’adresse saisie à l’inscription.
# MAIL_USER = compte utilisé pour *envoyer* (SMTP) ; le mail de vérification part toujours vers l’e-mail inscrit.
#
# Option sans mot de passe Gmail : Resend (https://resend.com) — clé API uniquement
# Puis : USE_ETHEREAL_IN_DEV=false ou supprimer cette ligne (sinon rien n’arrive dans Gmail).
# RESEND_API_KEY=re_xxxxxxxx
# MAIL_FROM=BMP.tn <onboarding@resend.dev>
#
# Gmail peut classer les mails transactionnels dans « Promotions » ; vérifiez aussi Indésirables.
# Pour viser l’onglet Principale : domaine vérifié + SPF/DKIM chez Resend (doc Resend).
#
# Sans RESEND ni MAIL_* en développement : erreur par défaut.
# Pour tester avec Ethereal uniquement en local : USE_ETHEREAL_IN_DEV=true
# En production : MAIL_HOST + MAIL_USER + MAIL_PASS obligatoires (pas d’Ethereal).
#
# Désactiver l’envoi et activer le compte sans vérification (démo uniquement) :
# ALLOW_REGISTRATION_WITHOUT_SMTP=true
#
# Exemple Gmail : activez la validation en 2 étapes, puis créez un « mot de passe d’application »
# et utilisez-le dans MAIL_PASS (pas le mot de passe du compte Google).
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_SECURE=false
# MAIL_USER=votrecompte@gmail.com
# MAIL_PASS=xxxxxxxxxxxxxxxx   (16 caractères sans espaces — mot de passe d’application)
# (optionnel) MAIL_TLS_REJECT_UNAUTHORIZED=true

# --- Analyse photo chantier (gratuit en local avec Ollama) ---
# auto (défaut) : toujours Ollama en premier ; si indisponible, Claude si ANTHROPIC_API_KEY.
#    (évite le +5 % quand la clé Anthropic est invalide mais Ollama tourne.)
# ollama : uniquement Ollama. anthropic : uniquement Claude.
# SUIVI_AI_PROVIDER=auto
#
# Ollama : https://ollama.com — installer, puis : ollama pull llava
# OLLAMA_HOST=http://127.0.0.1:11434
# OLLAMA_MODEL=llava
#
# Anthropic (payant / crédit) — optionnel si Ollama suffit
# ANTHROPIC_API_KEY=sk-ant-api03-...
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Incrément fixe (1–25) sur erreurs éligibles, y compris 401 / clé absente, en dev comme en prod.
# SUIVI_OFFLINE_PROGRESS_PER_PHOTO=8

# En développement uniquement : si non défini, +5 % quand la clé manque ou Anthropic répond 401/403.
# Mettre false pour garder l’avancement figé tant que la clé n’est pas valide.
# SUIVI_OFFLINE_ON_AUTH_ERROR=false
